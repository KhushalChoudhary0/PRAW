# Reddit OAuth Application Credentials
# Create a web application at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_REDIRECT_URI=http://localhost:8000/auth/callback
REDDIT_USER_AGENT=web:stealth-scraper-v1:0.1

# Session Security Key
# You can generate a random key using: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=your_super_secret_session_key_here
